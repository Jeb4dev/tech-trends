BLOB_READ_WRITE_TOKEN=""
POSTGRES_URL="postgres://user:pass@host:5432/dbname"
OPENAI_API_KEY=""
BACKFILL_TOKEN=""
DISABLE_BACKGROUND_SYNC=""

# SMTP settings for job alert emails (NodeMailer)
